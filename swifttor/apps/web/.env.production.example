# Copy these to Render Dashboard → swifttor-web → Environment
# Replace all placeholder values with your real credentials.

# ── API (your Render backend URL) ─────────────────────────────────
NEXT_PUBLIC_API_URL=https://swifttor-api.onrender.com

# ── NextAuth / Auth.js ────────────────────────────────────────────
NEXTAUTH_SECRET=<same-secret-as-api>
NEXTAUTH_URL=https://swifttor-web.onrender.com
AUTH_SECRET=<same-secret-as-api>
AUTH_URL=https://swifttor-web.onrender.com

# ── Google Maps ───────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=<your-google-maps-api-key>
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>

# ── Stripe ────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── PayPal ────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=<your-paypal-client-id>

# ── Sentry ────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Node ──────────────────────────────────────────────────────────
NODE_ENV=production
